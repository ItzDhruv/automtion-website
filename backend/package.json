{
  "name": "tg-live-backend",
  "version": "1.0.0",
  "description": "Node.js backend for remote Android device viewing and control using ADB and Scrcpy.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "nodemon dist/server.js"
  },
  "keywords": ["adb","scrcpy","socket.io","android","remote-control","typescript"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "sharp": "^0.32.5",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.19",
    "@types/node": "^20.14.2",
    "@types/socket.io": "^3.0.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
